# ---------------------------------------------------------------------------
# The Cardiology Clinic — environment variables
# Copy this file to `.env.local` for local development, and set the same
# values in the Vercel dashboard for production. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# --- Database (Neon Postgres) ----------------------------------------------
# Server-only secret. Stores referral submissions.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# --- Email notifications (Web3Forms) ---------------------------------------
# Access key used by the server-side API route to email a copy of each
# referral. (The old NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY name is still read as a
# fallback, so existing Vercel settings keep working.)
WEB3FORMS_ACCESS_KEY="your-web3forms-access-key"

# --- Patient reviews (Doctify) ---------------------------------------------
NEXT_PUBLIC_DOCTIFY_WIDGET_ID="037ze27k"

# ===========================================================================
# THIRD-PARTY INTEGRATIONS (Carebit / Semble / TouchPoints / iMedDoc)
# Leave any of these blank until the provider is live. The site automatically
# falls back to the phone / referral flow when they are empty.
# See INTEGRATIONS.md for provider-specific setup notes.
# ===========================================================================

# Online booking — OPTION A: embed the provider's booking widget in an iframe
# (e.g. Carebit "iframes/bookings/new" URL, or Semble online-booking token URL).
NEXT_PUBLIC_BOOKING_EMBED_URL=""

# Online booking — OPTION B: link out to the provider's hosted booking page.
# Used only if NEXT_PUBLIC_BOOKING_EMBED_URL is not set.
NEXT_PUBLIC_BOOKING_URL=""

# Patient portal — the provider's hosted patient login/portal URL.
# When set, a "Patient Portal" link appears in the header and footer.
NEXT_PUBLIC_PATIENT_PORTAL_URL=""

# Pay an invoice — the provider's secure online payment page.
# When set, a "Pay an invoice" panel appears on the Fees page.
NEXT_PUBLIC_PAY_INVOICE_URL=""
